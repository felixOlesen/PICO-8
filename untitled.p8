pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
x,y=12,12
c_h=4
end

function _update()
	
end

function _draw()
	cls(0)
	pset(x,y,12)
	--top square
	line(x-8,y,x,y+4,11)
	line(x+8,y,x,y+4,11)
	line(x+8,y,x,y-4,11)
	line(x-8,y,x,y-4,11)

	--bottom square
	line(x-8,y+c_h,x,y+4+c_h,11)
	line(x+8,y+c_h,x,y+4+c_h,11)
	
	--vertical lines
	line(x-8,y+c_h,x-8,y,11)
	line(x+8,y+c_h,x+8,y,11)
	line(x,y+4+c_h,x,y+4)
	
end
